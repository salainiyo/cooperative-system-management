ikimina.duckdns.org {
    # Match /auth and anything starting with /auth/
    handle /auth* {
        reverse_proxy cooperative_backend:80
    }
    
    # Match /api and anything starting with /api/
    handle /api* {
        reverse_proxy cooperative_backend:80
    }

    # Everything else to the frontend
    handle {
        reverse_proxy cooperative_frontend:80
    }
}